<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Schermata iniziale "Obsidian Casefile": lo sfondo noir (museo di notte) e
  impostato via CSS sulla classe .schermata-creazione. Sopra, una vignette
  scurisce i bordi per concentrare lo sguardo al centro (Chiaroscuro); titolo,
  campo nome (riquadro arrotondato nel colore del titolo), scheda delle
  caratteristiche, anteprima dello stile investigativo e bottone appoggiano
  direttamente sull'ambiente.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg125947.controller.CreazioneController"
           styleClass="schermata-creazione">

    <!-- Vignette: overlay che scurisce i bordi, trasparente ai click. -->
    <Region styleClass="vignette" mouseTransparent="true"/>

    <VBox alignment="CENTER" spacing="16" styleClass="contenuto-creazione" maxWidth="860">
        <!-- minWidth=-Infinity: il titolo usa sempre la larghezza preferita,
             senza mai venire troncato con i puntini di sospensione. -->
        <Label text="DELITTO AL MUSEO" styleClass="titolo-gioco" minWidth="-Infinity"/>
        <Label text="Inserisci il nome dell'investigatore" styleClass="etichetta"/>
        <TextField fx:id="campoNome" promptText="Es. Sherlock" maxWidth="320" styleClass="campo-nome"/>

        <!-- Scheda delle caratteristiche: distribuzione dei punti iniziali. -->
        <Label text="Distribuisci i punti caratteristica" styleClass="etichetta"/>
        <Label fx:id="puntiRimanenti" styleClass="punti-rimanenti"/>
        <VBox fx:id="schedaAttributi" alignment="CENTER" spacing="8" maxWidth="420"
              styleClass="scheda-attributi"/>

        <!-- Anteprima dello stile investigativo determinato dalla distribuzione. -->
        <Label fx:id="stileScelto" styleClass="didascalia" maxWidth="420" wrapText="true"/>

        <Button fx:id="inizia" text="INIZIA A GIOCARE" onAction="#onInizia" styleClass="bottone-principale"/>
        <Label fx:id="messaggioErrore" styleClass="messaggio-errore" wrapText="true" maxWidth="440"/>
    </VBox>
</StackPane>
